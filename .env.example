# ============================================================
# Party Map Daugavpils Bot — Environment Configuration
# ============================================================

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Bot owner Telegram ID (Super Admin)
OWNER_ID=123456789

# Database
DATABASE_URL=sqlite:///data/party_map.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/party_map

# Admin Panel
ADMIN_PANEL_SECRET=change_this_secret_key
ADMIN_PANEL_HOST=127.0.0.1
ADMIN_PANEL_PORT=8080

# File Storage
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# RSS Settings
RSS_FETCH_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/bot.log

# Points multipliers (for special events)
POINTS_MULTIPLIER_DEFAULT=1.0
POINTS_MULTIPLIER_BIRTHDAY_WEEK=2.0

# Referral system
REFERRAL_BONUS_REGISTRATION=40
REFERRAL_BONUS_FIRST_VISIT=30

# Currency
CURRENCY=EUR
